                    而车轮一般要“横着放”，让轮轴沿 y 轴或 x 轴方向，
                    所以这里要旋转一下，让轮子姿态正确。
                -->
      <origin rpy="1.57079635 0 0" xyz="0 0 0"/>
      <!-- 
                    material:
                    定义材质/颜色。

                    name="wheel_color":
                    材质名字叫 wheel_color。
                    如果多个地方使用同名材质，通常表示想复用这个材质。
                -->
      <material name="wheel_color">
        <!-- 
                        color:
                        rgba = 红 绿 蓝 透明度

                        0 0 0 表示黑色
                        最后一个 0.3 表示透明度 30%

                        注意：
                        这个值会让轮子看起来偏灰、偏淡、半透明。
                        如果你想要纯黑轮子，建议写成：
                        rgba="0 0 0 1"
                    -->
        <color rgba="0 0 0 0.3"/>
      </material>
    </visual>
  </link>
  <!-- ========================= -->
  <!-- 2-2. 定义轮子与车体的 joint -->
  <!-- ========================= -->
  <!-- 
            joint:
            用来连接两个 link，描述它们之间的相对运动关系。

            name="${wheel_name}2link":
            动态生成 joint 名字。
            例如：
            left2link
            right2link
        -->
  <joint name="right2link" type="continuous">
    <!-- 
                parent:
                父链接。
                这里轮子是挂在 base_link 上的，
                所以 base_link 是父链接。
            -->
    <parent link="base_link"/>
    <!-- 
                child:
                子链接。
                这里子链接就是当前定义的轮子 link。
            -->
    <child link="right_wheel"/>
    <!-- 
                origin:
                定义“子链接坐标系”相对于“父链接坐标系”的位姿。

                这和上面 visual 里的 origin 完全不是一回事，必须分清：

                - visual/origin:
                  调整“这个几何体在本 link 里怎么摆”

                - joint/origin:
                  调整“这个 link 整体安装到父 link 的什么位置”

                xyz:
