<launch>
    <!--
      物块颜色识别节点。

      默认使用当前仿真小车里的 RGB-D/Kinect 相机：
      - RGB 图像：/kinect/rgb/image_raw
      - 深度图像：/kinect/depth/image_raw
      - 相机内参：/kinect/rgb/camera_info

      查看调试图像：
        rqt_image_view /block_color_detector/debug_image

      查看识别结果：
        rostopic echo /block_color_detector/detections
    -->

    <arg name="rgb_topic" default="/kinect/rgb/image_raw" />
    <arg name="depth_topic" default="/kinect/depth/image_raw" />
    <arg name="camera_info_topic" default="/kinect/rgb/camera_info" />

    <!-- 小于这个像素面积的轮廓会被当成噪声忽略 -->
    <arg name="min_area" default="600" />

    <!--
      ROI：只识别图像中的指定区域，默认忽略底部 18%，减少小车自身被误识别。
      这些值是比例：0.0 表示最左/最上，1.0 表示最右/最下。
    -->
    <arg name="roi_x_min_ratio" default="0.05" />
    <arg name="roi_x_max_ratio" default="0.95" />
    <arg name="roi_y_min_ratio" default="0.00" />
    <arg name="roi_y_max_ratio" default="0.82" />

    <!-- 长宽比过滤：过滤明显不像方块的长条 -->
    <arg name="min_aspect_ratio" default="0.35" />
    <arg name="max_aspect_ratio" default="2.80" />

    <!-- 过大的色块通常是小车自身或墙面，默认过滤掉 -->
    <arg name="max_bbox_width_ratio" default="0.70" />
    <arg name="max_bbox_height_ratio" default="0.70" />

    <!-- 根据像素面积粗分 small / medium / large -->
    <arg name="small_area" default="2500" />
    <arg name="large_area" default="9000" />

    <!--
      当前 box_house.world 里颜色和形状是固定对应的：
      red/green/blue 是长方体，yellow/purple/cyan 是圆柱体。
      当深度特征不够明显时，启用这个提示可以减少误判。
    -->
    <arg name="use_color_shape_hints" default="true" />

    <node pkg="nav_demo" type="block_color_detector.py" name="block_color_detector" output="screen">
        <param name="rgb_topic" value="$(arg rgb_topic)" />
        <param name="depth_topic" value="$(arg depth_topic)" />
        <param name="camera_info_topic" value="$(arg camera_info_topic)" />
        <param name="min_area" value="$(arg min_area)" />
        <param name="roi_x_min_ratio" value="$(arg roi_x_min_ratio)" />
        <param name="roi_x_max_ratio" value="$(arg roi_x_max_ratio)" />
        <param name="roi_y_min_ratio" value="$(arg roi_y_min_ratio)" />
        <param name="roi_y_max_ratio" value="$(arg roi_y_max_ratio)" />
        <param name="min_aspect_ratio" value="$(arg min_aspect_ratio)" />
        <param name="max_aspect_ratio" value="$(arg max_aspect_ratio)" />
        <param name="max_bbox_width_ratio" value="$(arg max_bbox_width_ratio)" />
        <param name="max_bbox_height_ratio" value="$(arg max_bbox_height_ratio)" />
        <param name="small_area" value="$(arg small_area)" />
        <param name="large_area" value="$(arg large_area)" />
        <param name="use_color_shape_hints" value="$(arg use_color_shape_hints)" />
    </node>
</launch>
